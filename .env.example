# Paper Pigeon — environment template. Copy to `.env` and fill real values locally.
# `.env` and every `.env.*` (except this file) are gitignored. Deployed envs read these
# from the managed secret store (GitHub Actions encrypted secrets / AWS Secrets Manager),
# NOT from a committed file. Never paste a real secret into this template.

# ── Existing service (current Flask/AWS backend) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_KNOWLEDGE_BASE_ID_2=

# ── Repopulation Engine: scholarly APIs ─────────────────────────────────────
OPENALEX_API_KEY=
# Crossref polite pool — an identifying contact, not a secret, but configured here.
CROSSREF_MAILTO=
# PubMed E-utilities require tool + email params on every call.
PUBMED_TOOL=paper-pigeon
PUBMED_EMAIL=

# ── Repopulation Engine: AI gateway / models ────────────────────────────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# OpenRouter spend cap (GitHub secret name: paperpigeonbudget). Model tiering uses cheap
# models for bulk extraction/descriptions and escalates only on low confidence.
OPENROUTER_BUDGET=

# ── Feature flags ───────────────────────────────────────────────────────────
# Use Docling for PDF/HTML → structured text in the extraction path (GitHub secret: prefer_docling).
PREFER_DOCLING=false

# ── New data plane (filled in as Phase 1 infra comes up) ────────────────────
# Read-only role for the Postgres MCP server (see .mcp.json → postgres).
DATABASE_URL_RO=
# App's read/write connection (workers, API) — keep separate from the RO role.
DATABASE_URL=

# ── MCP server credentials (consumed by .mcp.json) ──────────────────────────
# GitHub PAT (repo + read:org) for the GitHub MCP server.
GITHUB_PAT=
# Optional Context7 key for higher rate limits; blank works for light use.
CONTEXT7_API_KEY=
